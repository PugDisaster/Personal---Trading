<script>
// ═══════════════════════════════════════════════════════════
//  ★  EDIT THIS DATA BLOCK — everything else auto-renders  ★
// ═══════════════════════════════════════════════════════════
const DATA = {
  ticker: "$TICKER",
  date: "YYYY-MM-DD",
  currentPrice: null,       // e.g. 425.50

  resistance: [
    { label: "R1", price: null, basis: "Prior high / gap", strength: "strong" },
    { label: "R2", price: null, basis: "",                  strength: "medium" },
    { label: "R3", price: null, basis: "",                  strength: "weak"   },
  ],
  support: [
    { label: "S1", price: null, basis: "200-day SMA / prior low", strength: "strong" },
    { label: "S2", price: null, basis: "",                         strength: "medium" },
    { label: "S3", price: null, basis: "",                         strength: "weak"   },
  ],
  mas: [
    { name: "200-Day SMA", price: null, position: "below" },  // above / below / at
    { name: "75-Day SMA",  price: null, position: "below" },
    { name: "50-Day SMA",  price: null, position: "below" },
    { name: "20-Day EMA",  price: null, position: "below" },
  ],
  stats: {
    "52W High":         null,
    "52W Low":          null,
    "ATH":              null,
    "Avg Vol (30D)":    null,
  },
  momentum: [
    { name: "RSI (14)",     reading: null, signal: "neutral" },  // bullish/bearish/neutral/oversold/overbought
    { name: "MACD",         reading: null, signal: "neutral" },
    { name: "ATR (14)",     reading: null, signal: "normal"  },  // high/normal/low
    { name: "Stoch %K",     reading: null, signal: "neutral" },
  ],
  signals: [
    { label: "Higher low vs. prior swing",        status: null },  // yes / no / partial
    { label: "Reclaim of 200-day SMA",            status: null },
    { label: "Reclaim of 75-day SMA",             status: null },
    { label: "Bounce off key support w/ volume",  status: null },
    { label: "RSI bullish divergence",            status: null },
    { label: "MACD bullish cross",                status: null },
    { label: "Volume dry-up on pullback",         status: null },
    { label: "Volume expansion on up days",       status: null },
    { label: "Compression / squeeze (low ATR)",   status: null },
    { label: "Earnings flush + recovery",         status: null },
  ],
  summary: "<!-- Fill in your technical summary here. What phase is the stock in? Entry zone? Invalidation? -->",
  entryZone: [null, null],    // [low, high]
  invalidation: null,
  targetR1: null,
  targetR2: null,
};
// ═══════════════════════════════════════════════════════════

const fmt = v => v == null ? "—" : "$" + v.toLocaleString("en-US", {minimumFractionDigits:2,maximumFractionDigits:2});
const fmtPct = (a, b) => {
  if (a == null || b == null) return "—";
  const pct = ((a - b) / b * 100).toFixed(1);
  return (pct >= 0 ? "+" : "") + pct + "%";
};

// Title & date
document.getElementById("ticker-title").textContent = DATA.ticker + " — Technical Analysis";
document.getElementById("analysis-date").textContent = "Last updated: " + (DATA.date || "—");

// Resistance
const resDiv = document.getElementById("resistance-levels");
DATA.resistance.forEach(l => {
  resDiv.innerHTML += `<div class="level-row">
    <div class="level-dot" style="background:#f85149"></div>
    <div class="level-label">${l.label}</div>
    <div class="level-price">${fmt(l.price)}</div>
    <div class="level-basis">${l.basis}</div>
    <span class="level-badge ${l.strength}">${l.strength}</span>
  </div>`;
});

// Support
const supDiv = document.getElementById("support-levels");
DATA.support.forEach(l => {
  supDiv.innerHTML += `<div class="level-row">
    <div class="level-dot" style="background:#3fb950"></div>
    <div class="level-label">${l.label}</div>
    <div class="level-price">${fmt(l.price)}</div>
    <div class="level-basis">${l.basis}</div>
    <span class="level-badge ${l.strength}">${l.strength}</span>
  </div>`;
});

// MAs
const maDiv = document.getElementById("ma-list");
DATA.mas.forEach(m => {
  const pillClass = m.position === "above" ? "pill-above" : m.position === "below" ? "pill-below" : "pill-at";
  const pillText = m.position === "above" ? "Above ▲" : m.position === "below" ? "Below ▼" : "At ◆";
  maDiv.innerHTML += `<div class="ma-row">
    <span class="ma-name">${m.name}</span>
    <span class="ma-price">${fmt(m.price)}</span>
    <span class="pill ${pillClass}">${pillText}</span>
  </div>`;
});

// Stats
const statsDiv = document.getElementById("price-stats");
const p = DATA.currentPrice;
const statsMap = {
  ...DATA.stats,
  "Current Price": p,
  "↓ from 52W High": DATA.stats["52W High"] ? fmtPct(p, DATA.stats["52W High"]) : "—",
  "↑ from 52W Low":  DATA.stats["52W Low"]  ? fmtPct(p, DATA.stats["52W Low"])  : "—",
  "↓ from ATH":      DATA.stats["ATH"]      ? fmtPct(p, DATA.stats["ATH"])      : "—",
};
Object.entries(statsMap).forEach(([k,v]) => {
  let cls = "";
  if (typeof v === "string" && v.startsWith("+")) cls = "up";
  else if (typeof v === "string" && v.startsWith("-")) cls = "down";
  else if (k === "Current Price") cls = "neu";
  const disp = (k.includes("High") || k.includes("Low") || k.includes("ATH") || k === "Current Price")
    ? (typeof v === "number" ? fmt(v) : v) : v;
  statsDiv.innerHTML += `<div class="stat"><span class="stat-label">${k}</span><span class="stat-val ${cls}">${disp ?? "—"}</span></div>`;
});

// Momentum
const momDiv = document.getElementById("momentum");
DATA.momentum.forEach(m => {
  const sigColors = {bullish:"up",bearish:"down",neutral:"",oversold:"down",overbought:"up",high:"down",normal:"",low:"up"};
  const cls = sigColors[m.signal] || "";
  momDiv.innerHTML += `<div class="stat">
    <span class="stat-label">${m.name}</span>
    <span class="stat-val">
      ${m.reading != null ? m.reading : "—"}
      <span class="${cls}" style="font-size:0.75rem;margin-left:6px;">${m.signal}</span>
    </span>
  </div>`;
});

// Checklist
const chkDiv = document.getElementById("checklist");
DATA.signals.forEach(s => {
  const icon = s.status === "yes" ? "✅" : s.status === "partial" ? "🟡" : "⬜";
  const cls  = s.status === "yes" ? "signal-yes" : s.status === "partial" ? "signal-partial" : "signal-no";
  chkDiv.innerHTML += `<div class="check-item"><span class="check-icon">${icon}</span><span class="${cls}">${s.label}</span></div>`;
});

// Summary
document.getElementById("summary-text").innerHTML = DATA.summary +
  (DATA.entryZone[0] ? `<br><br><strong>Entry zone:</strong> ${fmt(DATA.entryZone[0])} – ${fmt(DATA.entryZone[1])}` : "") +
  (DATA.invalidation ? `&nbsp;&nbsp;<strong>Invalidation:</strong> ${fmt(DATA.invalidation)}` : "") +
  (DATA.targetR1 ? `&nbsp;&nbsp;<strong>R1:</strong> ${fmt(DATA.targetR1)}` : "") +
  (DATA.targetR2 ? `&nbsp;&nbsp;<strong>R2:</strong> ${fmt(DATA.targetR2)}` : "");

// ── CHART ──────────────────────────────────────────────────
(function drawChart() {
  const svg = document.getElementById("price-chart");
  const W = 900, H = 320, PL = 70, PR = 20, PT = 20, PB = 30;
  const cw = W - PL - PR, ch = H - PT - PB;

  const allPrices = [
    DATA.currentPrice,
    ...DATA.resistance.map(r=>r.price),
    ...DATA.support.map(s=>s.price),
    ...DATA.mas.map(m=>m.price),
    DATA.stats["52W High"], DATA.stats["52W Low"],
    DATA.entryZone[0], DATA.entryZone[1],
    DATA.invalidation, DATA.targetR1, DATA.targetR2,
  ].filter(p => p != null);

  if (allPrices.length < 2) {
    svg.innerHTML = `<text x="450" y="160" fill="#7d8590" text-anchor="middle" font-size="14">Fill in price data to render chart</text>`;
    return;
  }

  const minP = Math.min(...allPrices) * 0.97;
  const maxP = Math.max(...allPrices) * 1.03;
  const yScale = p => PT + ch - ((p - minP) / (maxP - minP)) * ch;
  const ns = "http://www.w3.org/2000/svg";

  const mk = (tag, attrs) => {
    const el = document.createElementNS(ns, tag);
    Object.entries(attrs).forEach(([k,v]) => el.setAttribute(k,v));
    return el;
  };

  // Grid lines
  for (let i = 0; i <= 5; i++) {
    const p = minP + (maxP - minP) * (i / 5);
    const y = yScale(p);
    svg.appendChild(mk("line",{x1:PL,y1:y,x2:W-PR,y2:y,stroke:"#21262d",strokeWidth:1}));
    const t = mk("text",{x:PL-6,y:y+4,fill:"#7d8590","text-anchor":"end","font-size":"10"});
    t.textContent = "$" + p.toFixed(0);
    svg.appendChild(t);
  }

  const drawLine = (price, color, dash="", label="", side="right") => {
    if (price == null) return;
    const y = yScale(price);
    const line = mk("line",{x1:PL,y1:y,x2:W-PR,y2:y,stroke:color,"stroke-width":"1.5"});
    if (dash) line.setAttribute("stroke-dasharray", dash);
    svg.appendChild(line);
    const tx = side === "left" ? PL + 4 : W - PR - 4;
    const anchor = side === "left" ? "start" : "end";
    const t = mk("text",{x:tx,y:y-3,fill:color,"font-size":"10","text-anchor":anchor,"font-weight":"600"});
    t.textContent = label ? `${label} ${fmt(price)}` : fmt(price);
    svg.appendChild(t);
  };

  // Resistance
  DATA.resistance.forEach((r,i) => drawLine(r.price, "#f85149", "4,3", r.label, i%2===0?"right":"left"));
  // Support
  DATA.support.forEach((s,i) => drawLine(s.price, "#3fb950", "4,3", s.label, i%2===0?"right":"left"));
  // MAs
  const maColors = ["#58a6ff","#bc8cff","#d29922","#39d353"];
  DATA.mas.forEach((m,i) => drawLine(m.price, maColors[i], "6,3", m.name.split("-")[0]+"d", "left"));
  // Entry zone shading
  if (DATA.entryZone[0] && DATA.entryZone[1]) {
    const y1 = yScale(DATA.entryZone[1]), y2 = yScale(DATA.entryZone[0]);
    svg.appendChild(mk("rect",{x:PL,y:y1,width:cw,height:y2-y1,fill:"rgba(88,166,255,0.07)"}));
  }
  // Invalidation
  drawLine(DATA.invalidation, "#f85149", "2,2", "STOP", "left");
  // Targets
  drawLine(DATA.targetR1, "#3fb950", "2,2", "T1", "right");
  drawLine(DATA.targetR2, "#3fb950", "2,2", "T2", "right");
  // Current price — solid bold
  if (DATA.currentPrice) {
    const y = yScale(DATA.currentPrice);
    svg.appendChild(mk("line",{x1:PL,y1:y,x2:W-PR,y2:y,stroke:"#e6edf3","stroke-width":"2.5"}));
    svg.appendChild(mk("circle",{cx:PL+cw/2,cy:y,r:"5",fill:"#e6edf3"}));
    const t = mk("text",{x:PL+cw/2+8,y:y-5,fill:"#e6edf3","font-size":"11","font-weight":"700"});
    t.textContent = "NOW " + fmt(DATA.currentPrice);
    svg.appendChild(t);
  }
})();
</script>
